<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    android:fillViewport="true"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="تسجيل دخول المحصل"
            android:textColor="#0B5CAD"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="أدخل بيانات الدخول للمتابعة"
            android:textColor="#666666"
            android:textSize="15sp"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etBaseUrl"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="رابط الخادم HTTPS"
            android:text="https://192.168.0.135:8443/"
            android:inputType="textUri"
            android:singleLine="true"
            android:layoutDirection="ltr"
            android:textDirection="ltr"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@android:drawable/edit_text"
            android:textColor="#111111"
            android:textColorHint="#777777" />
        <Button
            android:id="@+id/btnFindServer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="بحث تلقائي عن السيرفر"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00A676" />
        <EditText
            android:id="@+id/etUserName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:hint="اسم المستخدم"
            android:inputType="text"
            android:singleLine="true"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@android:drawable/edit_text"
            android:textColor="#111111"
            android:textColorHint="#777777" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:hint="كلمة المرور"
            android:inputType="textPassword"
            android:singleLine="true"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@android:drawable/edit_text"
            android:textColor="#111111"
            android:textColorHint="#777777" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:text="دخول"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0B5CAD" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textColor="#B00020"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>