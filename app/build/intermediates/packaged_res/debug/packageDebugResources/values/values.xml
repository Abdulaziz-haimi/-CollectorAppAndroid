<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:ns1="http://schemas.android.com/tools">
    <color name="accentColor">#00A676</color>
    <color name="accentLightColor">#E7FFF7</color>
    <color name="backgroundColor">#F5F7FB</color>
    <color name="black">#000000</color>
    <color name="errorColor">#B00020</color>
    <color name="primaryColor">#0B5CAD</color>
    <color name="primaryDarkColor">#073B73</color>
    <color name="primaryLightColor">#EAF3FF</color>
    <color name="surfaceColor">#FFFFFF</color>
    <color name="textPrimaryColor">#111827</color>
    <color name="textSecondaryColor">#6B7280</color>
    <color name="warningColor">#F59E0B</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">Collector App</string>
    <string name="home">Home</string>
    <string name="login">Login</string>
    <style name="Theme.CollectorApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorPrimaryContainer">@color/primaryDarkColor</item>
        <item name="colorSecondary">@color/accentColor</item>

        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="android:fontFamily">sans</item>

        <item name="android:statusBarColor">@color/primaryDarkColor</item>
        <item name="android:navigationBarColor">@color/backgroundColor</item>
        <item name="android:windowLightStatusBar" ns1:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" ns1:targetApi="27">true</item>

        <item name="android:layoutDirection">rtl</item>
        <item name="android:textDirection">rtl</item>
    </style>
</resources>